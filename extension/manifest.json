{
  "manifest_version": 3,
  "name": "LexPack — КонсультантПлюс",
  "version": "0.8.3",
  "minimum_chrome_version": "120",
  "description": "Поиск и массовое сохранение документов из браузерной версии КонсультантПлюс.",
  "permissions": [
    "alarms",
    "downloads",
    "offscreen",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://consultant.ru/*",
    "https://*.consultant.ru/*"
  ],
  "action": {
    "default_title": "LexPack",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://consultant.ru/*",
        "https://*.consultant.ru/*"
      ],
      "js": [
        "shared/filename.js",
        "shared/runtime.js",
        "content/adapters/public-site.js",
        "content/adapters/online-app.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
